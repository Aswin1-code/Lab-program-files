#!/bin/bash
echo "Enter size(N)"
read N
i=1
max=0
echo "Enter Numbers"
while [ $i -le $N ]
do 
   read num
 if [ $i -eq 1 ]    #set first number as max
     then
      max=$num
 else             #from number 2 update max if the num>max
   if [ $num -gt $max ]
     then
   max=$num
   fi
fi
i=$((i+1))          #increment by 1
done
echo "The largest number is "
echo $max


